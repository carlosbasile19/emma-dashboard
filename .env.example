# Emma Dashboard — environment variables
# Copy to .env.local (gitignored) and fill in real values.

# --- Olivia external API (SERVER-ONLY — never expose to the browser) ---
# Agency-scoped key, format oa_live_...  Sent as the `x-api-key` header.
# Scopes used by this app: dashboard:read (analytics), dashboard:brief (Brief Emma voice),
# dashboard:report (Reporting walkthrough voice). Optional dashboard:pii lets Olivia speak lead
# names in the schedule/looms; without it she gives counts + metrics only.
OLIVIA_API_KEY=oa_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Olivia production host (no trailing slash).
OLIVIA_API_BASE=https://www.lunarolivia.com

# --- Supabase (public — safe for the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# --- Supabase service role (SERVER-ONLY — never expose to the browser) ---
# Used by provisioning + server-side admin/snapshot tasks only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Briefing bridge (OFF until the Olivia backend ships the endpoint) ---
# Set to true once Olivia exposes POST /api/external/v1/clients/{id}/briefings.
# OLIVIA_BRIEFING_ENABLED=false

# --- Reporting bridge (OFF until the Olivia backend ships the endpoint) ---
# Set to true once Olivia exposes POST /api/external/v1/clients/{id}/reporting AND the key above
# carries the dashboard:report scope. Until then the Reporting walkthrough runs a local preview.
# OLIVIA_REPORTING_ENABLED=false

# --- Snapshot cron (Phase 8 seam — OFF by default) ---
# Leave unset/false. Set to true only when activating daily snapshots.
# SNAPSHOTS_ENABLED=false
# Secret the Vercel cron must send (Authorization: Bearer <CRON_SECRET>) when enabled.
# CRON_SECRET=

# --- Email (Resend) ---
# Resend API key (SERVER-ONLY). From a verified heyemma.io sender.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where replies to transactional emails go (monitored inbox).
EMAIL_REPLY_TO=carlos@imperoagency.com
# Supabase "Send Email" auth-hook signing secret (Auth → Hooks). Format: v1,whsec_...
SEND_EMAIL_HOOK_SECRET=v1,whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
